# ═══════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual envs
.venv/
venv/
env/
ENV/

# Celery runtime state
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid

# ═══════════════════════════════════════════════════════════
# Node / Vite (frontend)
# ═══════════════════════════════════════════════════════════
node_modules/
dist/
build/
.vite/
.next/
.nuxt/
*.tsbuildinfo
.eslintcache

# ═══════════════════════════════════════════════════════════
# Env files / секреты
# ═══════════════════════════════════════════════════════════
.env
.env.*
!.env.example
*.pem
*.key

# ═══════════════════════════════════════════════════════════
# Telegram приватные данные
# ═══════════════════════════════════════════════════════════
sessions/
*.session
*.session-journal
tdata/
data/
!data/.gitkeep
!sessions/.gitkeep

# Photos для сториз (per-account)
api/account_media/
!api/account_media/.gitkeep

# ═══════════════════════════════════════════════════════════
# Логи
# ═══════════════════════════════════════════════════════════
logs/
*.log
!logs/.gitkeep

# ═══════════════════════════════════════════════════════════
# IDE / редакторы
# ═══════════════════════════════════════════════════════════
.idea/
.vscode/
*.swp
*.swo
.claude/

# ═══════════════════════════════════════════════════════════
